{
  "name": "uz-payment-sdk",
  "version": "0.1.0",
  "description": "Neutral payment SDK core for Uzbekistan providers.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bek2000u/uz-payment-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/bek2000u/uz-payment-sdk/issues"
  },
  "homepage": "https://github.com/bek2000u/uz-payment-sdk#readme",
  "keywords": [
    "payments",
    "uzbekistan",
    "payme",
    "click",
    "uzum",
    "typescript",
    "sdk"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "prebuild": "npm run clean",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test:node": "npm test",
    "test:bun": "bun test",
    "test:contracts": "jest --runInBand --testPathPattern=contract\\.spec\\.ts$",
    "test:matrix": "npm run typecheck && npm run test:contracts && npm run test:node && npm run test:bun",
    "test": "jest --runInBand",
    "release:smoke": "npm run clean && npm run typecheck && npm run test && npm run build && node -e \"require('./dist/index.js')\" && node ./scripts/smoke-consumer.cjs",
    "prepublishOnly": "npm run release:smoke"
  },
  "dependencies": {
    "axios": "^1.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.3"
  }
}
