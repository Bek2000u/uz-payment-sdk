# Payment SDK - Environment Variables

# Application Configuration
NODE_ENV=development

# Payme Configuration
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_KEY=your_payme_key
PAYME_API_URL=https://checkout.test.paycom.uz/api

# Click Configuration  
CLICK_SERVICE_ID=your_click_service_id
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_MERCHANT_USER_ID=your_click_merchant_user_id
CLICK_SECRET_KEY=your_click_secret_key
CLICK_API_URL=https://api.click.uz/v2/merchant

# Uzum Configuration
UZUM_TERMINAL_ID=your_uzum_terminal_id
UZUM_API_KEY=your_uzum_api_key
UZUM_API_URL=https://developer.uzumbank.uz
UZUM_CONTENT_LANGUAGE=ru

# Optional webhook forwarding
ENTERPRISE_WEBHOOK_URL=https://hooks.example.com/payments
ENTERPRISE_WEBHOOK_SECRET=your_webhook_secret
ENTERPRISE_WEBHOOK_TIMEOUT_MS=5000
ENTERPRISE_WEBHOOK_SOURCE=payment-sdk
ENTERPRISE_WEBHOOK_HEADER_PREFIX=X-Payment-SDK
